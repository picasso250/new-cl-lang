import io
import math

fun main() {
    io.println(math.sqrt(9.0))
    io.println(math.pow(2.0, 3.0))
    io.println(math.floor(1.9))
    io.println(math.ceil(1.1))
    io.println(math.round(1.6))
    io.println(math.cos(0.0))
    io.println(math.sin(0.0))
    io.println(math.log(math.e()))
}

# STDOUT: 3
# STDOUT: 8
# STDOUT: 1
# STDOUT: 2
# STDOUT: 2
# STDOUT: 1
# STDOUT: 0
# STDOUT: 1
